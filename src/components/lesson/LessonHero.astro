---
interface Props {
  title: string;
  module: string;
  moduleId: string;
  duration: string;
  focus: string;
  level: string;
}

const { title, module, moduleId, duration, focus, level } = Astro.props;
---

<section class="lesson-hero">
  <div class="container">
    <div class="lesson-hero-shell">
      <div class="lesson-hero-topline">
        <p class="lesson-kicker">Lesson in {module}</p>
        <div class="lesson-hero-actions">
          <a href={`/modules/${moduleId}`} class="lesson-hero-module-link">Open module overview</a>
          <button type="button" class="lesson-hero-print" data-lesson-print-trigger>Print lesson</button>
        </div>
      </div>

      <div class="lesson-hero-content">
        <h1>{title}</h1>
        <p class="lesson-focus-copy page-subheading">{focus}</p>
      </div>

      <div class="lesson-meta">
        <div class="lesson-meta-item">
          <span class="lesson-meta-label">Module</span>
          <strong>{module}</strong>
        </div>
        <div class="lesson-meta-item">
          <span class="lesson-meta-label">Estimated time</span>
          <strong>{duration}</strong>
        </div>
        <div class="lesson-meta-item">
          <span class="lesson-meta-label">Level</span>
          <strong>{level}</strong>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const lessonPrintButton = document.querySelector('[data-lesson-print-trigger]');

  if (lessonPrintButton instanceof HTMLButtonElement) {
    lessonPrintButton.addEventListener('click', () => {
      window.print();
    });
  }
</script>

<style>
  .lesson-hero {
    background:
      radial-gradient(circle at top right, rgba(243, 214, 172, 0.2), transparent 24rem),
      radial-gradient(circle at top left, rgba(52, 116, 93, 0.1), transparent 22rem),
      linear-gradient(180deg, rgba(248, 243, 234, 0.97), rgba(255, 255, 255, 0.12));
    padding: 1.65rem 0 1.05rem;
    margin-bottom: 2.35rem;
  }

  .lesson-hero-shell {
    max-width: 1080px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(240px, 0.7fr);
    gap: 1.35rem 2rem;
    padding: clamp(1.7rem, 4vw, 2.8rem);
    border-radius: 1.5rem;
    overflow: hidden;
    position: relative;
    background:
      radial-gradient(circle at top right, rgba(243, 214, 172, 0.22), transparent 15rem),
      radial-gradient(circle at bottom left, rgba(63, 92, 82, 0.1), transparent 18rem),
      linear-gradient(145deg, rgba(255, 255, 255, 0.99), rgba(249, 244, 236, 0.97));
    border: 1px solid rgba(24, 34, 48, 0.08);
    box-shadow: 0 30px 60px -38px rgba(24, 34, 48, 0.34);
    color: var(--color-text);
  }

  .lesson-hero-shell::after {
    content: '';
    position: absolute;
    inset: auto 0 0;
    height: 8px;
    background: linear-gradient(90deg, rgba(63, 92, 82, 0.78), rgba(201, 111, 50, 0.7));
    opacity: 0.26;
  }

  .lesson-hero-topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    grid-column: 1 / -1;
    margin-bottom: 0.1rem;
    flex-wrap: wrap;
  }

  .lesson-kicker {
    margin: 0;
    color: var(--color-accent);
    font-family: var(--font-ui);
    font-size: 0.84rem;
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .lesson-hero-content {
    align-self: start;
    padding-right: 0.5rem;
  }

  .lesson-hero-content h1 {
    color: var(--color-primary-dark);
    margin-bottom: 0.82rem;
    font-size: clamp(2.8rem, 5vw, 4.2rem);
    line-height: 1.04;
    max-width: 11ch;
    text-wrap: balance;
    background: linear-gradient(135deg, var(--color-primary-dark) 12%, var(--color-primary) 58%, var(--color-secondary) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow: 0 10px 24px rgba(24, 34, 48, 0.08);
  }

  .lesson-meta {
    margin-top: 0;
    display: grid;
    grid-template-columns: 1fr;
    align-content: start;
    gap: 0.7rem;
    padding: 1.05rem;
    border-radius: 1.25rem;
    background: rgba(255, 255, 255, 0.74);
    border: 1px solid rgba(24, 34, 48, 0.08);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(8px);
  }

  .lesson-meta-item {
    display: grid;
    gap: 0.12rem;
    min-width: 0;
    padding: 0.88rem 0.92rem;
    border-radius: 0.95rem;
    background: rgba(255, 255, 255, 0.84);
    border: 1px solid rgba(24, 34, 48, 0.06);
  }

  .lesson-meta-label {
    color: var(--color-text-secondary);
    font-family: var(--font-ui);
    font-size: 0.78rem;
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .lesson-meta-item strong {
    color: var(--color-primary-dark);
    font-size: 0.98rem;
    font-weight: var(--font-weight-semibold);
  }

  .lesson-focus-copy {
    max-width: 40rem;
  }

  .lesson-hero-actions {
    display: inline-flex;
    align-items: center;
    justify-content: flex-end;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .lesson-hero-module-link,
  .lesson-hero-print {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.8rem;
    padding: 0.7rem 0.95rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.76);
    color: var(--color-primary-dark);
    font-family: var(--font-ui);
    font-size: 0.95rem;
    font-weight: var(--font-weight-semibold);
    text-decoration: none;
    transition:
      transform var(--transition-base),
      background-color var(--transition-base),
      box-shadow var(--transition-base);
    border: 1px solid rgba(24, 34, 48, 0.08);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.74);
  }

  .lesson-hero-print {
    cursor: pointer;
  }

  .lesson-hero-module-link:hover,
  .lesson-hero-print:hover {
    transform: translateY(-1px);
    background: white;
    box-shadow: var(--shadow-sm);
    text-decoration: none;
  }

  .lesson-hero-print:focus-visible {
    outline: 2px solid rgba(52, 116, 93, 0.28);
    outline-offset: 3px;
  }

  @media (max-width: 768px) {
    .lesson-hero {
      padding-top: 1rem;
    }

    .lesson-hero-shell {
      grid-template-columns: 1fr;
      gap: 1rem;
      padding: 1.3rem 1.15rem 1.2rem;
    }

    .lesson-hero-content {
      padding-right: 0;
    }

    .lesson-hero-actions {
      justify-content: flex-start;
    }

    .lesson-hero-content h1 {
      max-width: none;
      font-size: clamp(2.2rem, 8vw, 3rem);
    }

    .lesson-meta {
      padding: 0;
      background: transparent;
      border: none;
      box-shadow: none;
      backdrop-filter: none;
    }

    .lesson-meta-item {
      width: 100%;
    }
  }

  @media print {
    .lesson-hero {
      padding: 0 0 1rem;
      margin-bottom: 1rem;
      background: none;
    }

    .lesson-hero-shell {
      display: block;
      padding: 0;
      border: none;
      border-radius: 0;
      background: none;
      box-shadow: none;
    }

    .lesson-hero-shell::after,
    .lesson-hero-actions {
      display: none !important;
    }

    .lesson-hero-topline {
      display: block;
      margin-bottom: 0.5rem;
    }

    .lesson-kicker {
      margin-bottom: 0.4rem;
    }

    .lesson-hero-content h1 {
      max-width: none;
      font-size: 24pt;
    }

    .lesson-focus-copy {
      max-width: none;
    }

    .lesson-meta {
      margin-top: 1rem;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.5rem;
      padding: 0;
      border: none;
      background: none;
      box-shadow: none;
      backdrop-filter: none;
    }

    .lesson-meta-item {
      padding: 0.7rem 0.8rem;
      background: none;
      border: 1px solid var(--color-border);
      box-shadow: none;
      break-inside: avoid;
    }
  }
</style>
