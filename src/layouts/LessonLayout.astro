      }

      .lesson-markdown--chaptered {
        padding: 0;
        border: none;
        border-radius: 0;
        background: none;
        box-shadow: none;
      }

      .lesson-markdown--chaptered .lesson-heading-chapter,
      .lesson-markdown--chaptered .lesson-heading-section,
      .lesson-markdown--chaptered .lesson-heading-example,
      .lesson-markdown--chaptered .lesson-example-list,
      .lesson-markdown--chaptered .lesson-labeled-list,
      .lesson-markdown--chaptered .lesson-labeled-list-ol > li,
      .content-prose blockquote,
      .content-prose pre {
