---
import fs from 'fs';
import path from 'path';
import matter from 'gray-matter';
import BaseLayout from '../layouts/BaseLayout.astro';

// Load all lesson files
const lessonsDir = path.join(process.cwd(), 'src/content/lessons');
const files = fs.readdirSync(lessonsDir).filter(f => f.endsWith('.md'));

const lessons = files.map(file => {
  const filePath = path.join(lessonsDir, file);
  const content = fs.readFileSync(filePath, 'utf-8');
  const { data } = matter(content);
  return { data };
});

// Group lessons by module
const moduleOrder = ['foundations', 'tenses', 'accuracy', 'complex-grammar', 'style', 'mastery'];
const curriculum = {
  foundations: {
    title: 'Module 1: Foundations of Grammar',
    description: 'Build a clean base in word classes, sentence architecture, and noun phrases before moving into more advanced control.',
    tasks: 'Write a 150-word self-introduction and label nouns, verbs, articles, and sentence types.',
    lessons: lessons.filter(l => l.data.moduleId === 'foundations'),
  },
  tenses: {
    title: 'Module 2: Tenses and Time',
    description: 'Master every tense form from simple to progressive, perfect to modal, and understand the meaning differences that matter for communication.',
    tasks: 'Create a timeline of your week and write sentences using different tenses for past, present, and future.',
    lessons: lessons.filter(l => l.data.moduleId === 'tenses'),
  },
  accuracy: {
    title: 'Module 3: Sentence Accuracy',
    description: 'Build confidence making sentences that are grammatically sound, then move beyond accuracy to style and impact.',
    tasks: 'Edit a flawed paragraph covering agreement, pronouns, prepositions, and voice.',
    lessons: lessons.filter(l => l.data.moduleId === 'accuracy'),
  },
  'complex-grammar': {
    title: 'Module 4: Complex Grammar',
    description: 'Handle sophisticated sentence structures: relative clauses, conditionals, reported speech, and verb patterns that unlock formal and technical writing.',
    tasks: 'Rewrite simple sentences into complex structures using clauses, conditionals, and reported speech.',
    lessons: lessons.filter(l => l.data.moduleId === 'complex-grammar'),
  },
  style: {
    title: 'Module 5: Style and Editing',
    description: 'Move beyond correct to compelling. Master punctuation choices, parallel structure, and concision that make writing powerful.',
    tasks: 'Revise a sample text for clarity, parallelism, and tone.',
    lessons: lessons.filter(l => l.data.moduleId === 'style'),
  },
  mastery: {
    title: 'Module 6: Mastery and Review',
    description: 'Consolidate your knowledge through targeted error correction, transformations, and a comprehensive review ready you for any writing challenge.',
    tasks: 'Complete a final assessment covering all six modules.',
    lessons: lessons.filter(l => l.data.moduleId === 'mastery'),
  },
};
---

<BaseLayout title="Full Curriculum | English Grammar Atlas" description="21 premium grammar lessons organized across 6 progressive modules">
  <main class="main-content">
    <div class="container">
      <!-- Hero Section -->
      <section class="curriculum-hero">
        <h1>Complete Curriculum</h1>
        <p class="hero-subtitle">21 premium lessons across 6 progressive modules, from foundations to mastery</p>
      </section>

      <!-- Module Grid -->
      {
        moduleOrder.map((moduleId) => {
          const module = curriculum[moduleId];
          return (
            <section class="module-section">
              <a href={`/modules/${moduleId}`} style="text-decoration: none; color: inherit;">
                <div class="module-header">
                  <h2 class="module-title">{module.title}</h2>
                  <p class="module-description">{module.description}</p>
                  <div class="module-task">
                    <strong>Portfolio Task:</strong> {module.tasks}
                  </div>
                </div>
              </a>

              <div class="lessons-grid">
                {module.lessons
                  .sort((a, b) => (a.data.slug || '').localeCompare(b.data.slug || ''))
                  .map((lesson) => (
                    <a href={`/lessons/${lesson.data.slug}`} class="lesson-card">
                      <div class="lesson-card-header">
                        <h3>{lesson.data.title}</h3>
                        <span class="lesson-duration">{lesson.data.duration}</span>
                      </div>
                      <p class="lesson-focus">{lesson.data.focus}</p>
                      <div class="lesson-meta">
                        <span class="lesson-level">{lesson.data.level || 'Beginner'}</span>
                      </div>
                    </a>
                  ))}
              </div>
            </section>
          );
        })
      }

      <!-- Footer CTA -->
      <section class="curriculum-footer">
        <h2>Ready to master English grammar?</h2>
        <p>Start with Module 1 or jump to any lesson that interests you. Complete all lessons for a certified accomplishment.</p>
        <div class="button-group">
          <a href="/lessons/parts-of-speech" class="btn btn-primary">Start Lesson 1</a>
          <a href="/" class="btn btn-secondary">Back to Home</a>
        </div>
      </section>
    </div>
  </main>

  <style>
    .curriculum-hero {
      text-align: center;
      padding: var(--space-xl) 0;
      margin-bottom: var(--space-lg);
      border-bottom: 2px solid var(--color-border);
    }

    .curriculum-hero h1 {
      font-size: var(--font-size-4xl);
      margin-bottom: var(--space-sm);
    }

    .hero-subtitle {
      font-size: var(--font-size-lg);
      color: var(--color-text-secondary);
    }

    .module-section {
      margin-bottom: var(--space-2xl);
    }

    .module-header {
      margin-bottom: var(--space-lg);
      padding: var(--space-lg);
      padding-bottom: var(--space-lg);
      border-bottom: 2px solid var(--color-border);
      border-radius: var(--radius-md);
      transition: all 0.3s ease;
      cursor: pointer;
    }

    .module-section a[style*="text-decoration: none"] {
      display: block;
    }

    .module-section a[style*="text-decoration: none"]:hover .module-header {
      background-color: var(--color-bg-secondary);
      transform: translateX(4px);
    }

    .module-title {
      font-size: var(--font-size-2xl);
      color: var(--color-primary);
      margin-bottom: var(--space-md);
    }

    .module-description {
      font-size: var(--font-size-base);
      color: var(--color-text);
      margin-bottom: var(--space-md);
      line-height: 1.6;
    }

    .module-task {
      background-color: var(--color-bg-secondary);
      padding: var(--space-md);
      border-radius: var(--radius-md);
      font-size: var(--font-size-sm);
      color: var(--color-text);
    }

    .lessons-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: var(--space-lg);
      margin-bottom: var(--space-xl);
    }

    .lesson-card {
      background: var(--color-bg);
      border: 2px solid var(--color-border);
      border-radius: var(--radius-md);
      padding: var(--space-lg);
      text-decoration: none;
      color: inherit;
      transition: all var(--transition-normal);
    }

    .lesson-card:hover {
      border-color: var(--color-primary);
      box-shadow: var(--shadow-lg);
      transform: translateY(-4px);
    }

    .lesson-card-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: var(--space-md);
      gap: var(--space-sm);
    }

    .lesson-card-header h3 {
      font-size: var(--font-size-lg);
      color: var(--color-primary);
      margin: 0;
      flex: 1;
    }

    .lesson-duration {
      background-color: var(--color-primary-light);
      color: var(--color-primary);
      padding: var(--space-xs) var(--space-sm);
      border-radius: var(--radius-sm);
      font-size: var(--font-size-xs);
      font-weight: var(--font-weight-semibold);
      white-space: nowrap;
    }

    .lesson-focus {
      font-size: var(--font-size-sm);
      color: var(--color-text);
      margin-bottom: var(--space-md);
      line-height: 1.5;
    }

    .lesson-meta {
      display: flex;
      gap: var(--space-sm);
    }

    .lesson-level {
      background-color: var(--color-success-light);
      color: var(--color-success);
      padding: var(--space-xs) var(--space-sm);
      border-radius: var(--radius-sm);
      font-size: var(--font-size-xs);
      font-weight: var(--font-weight-semibold);
    }

    .curriculum-footer {
      text-align: center;
      padding: var(--space-2xl) var(--space-lg);
      background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
      border-radius: var(--radius-lg);
      color: white;
      margin-top: var(--space-2xl);
    }

    .curriculum-footer h2 {
      font-size: var(--font-size-2xl);
      margin-bottom: var(--space-md);
    }

    .curriculum-footer p {
      font-size: var(--font-size-base);
      margin-bottom: var(--space-lg);
    }

    .button-group {
      display: flex;
      gap: var(--space-md);
      justify-content: center;
      flex-wrap: wrap;
    }

    @media (max-width: 768px) {
      .curriculum-hero h1 {
        font-size: var(--font-size-3xl);
      }

      .module-title {
        font-size: var(--font-size-xl);
      }

      .lessons-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
