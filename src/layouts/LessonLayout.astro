        margin-bottom: 0.5rem;
      }

      .lesson-kicker {
        margin-bottom: 0.4rem;
      }

      .lesson-hero-content h1 {
        max-width: none;
        font-size: 24pt;
      }

      .lesson-focus-copy {
        max-width: none;
      }

      .lesson-meta {
        margin-top: 1rem;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.5rem;
        padding: 0;
        border: none;
        background: none;
        box-shadow: none;
        backdrop-filter: none;
      }

      .lesson-meta-item {
        padding: 0.7rem 0.8rem;
        background: none;
        border: 1px solid var(--color-border);
        box-shadow: none;
