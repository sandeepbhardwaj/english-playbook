---
import BaseLayout from './BaseLayout.astro';
import LessonHero from '../components/lesson/LessonHero.astro';
import LessonProse from '../components/lesson/LessonProse.astro';
import LessonNavigation from '../components/lesson/LessonNavigation.astro';
import LessonNextSteps from '../components/lesson/LessonNextSteps.astro';
import type { LessonNavigationItem } from '../lib/course';

interface Props {
  title: string;
  slug: string;
  module: string;
  moduleId: string;
  duration: string;
  focus: string;
  level: string;
  previousLesson?: LessonNavigationItem;
  nextLesson?: LessonNavigationItem;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const { title, slug, module, moduleId, duration, focus, level, previousLesson, nextLesson, structuredData } = Astro.props;
---

<BaseLayout title={`${title} | English Grammar Atlas`} description={focus} structuredData={structuredData}>
  <article class:list={['lesson', `lesson--${slug}`]} data-lesson-slug={slug}>
    <LessonHero
      title={title}
      module={module}
      moduleId={moduleId}
      duration={duration}
      focus={focus}
      level={level}
    />

    <LessonProse>
      <slot />
    </LessonProse>

    <LessonNavigation
      module={module}
      moduleId={moduleId}
      previousLesson={previousLesson}
      nextLesson={nextLesson}
    />

    <LessonNextSteps slug={slug} />
  </article>

  <style>
    .lesson {
      background-color: var(--color-background);
    }

    @media print {
      .lesson {
        background: white;
      }
    }
  </style>
</BaseLayout>
