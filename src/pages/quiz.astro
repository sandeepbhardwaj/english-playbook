---
import BaseLayout from '../layouts/BaseLayout.astro';
import { curriculumModules, sortLessonEntries } from '../lib/course';
import { loadLessons } from '../lib/lesson-files';
import { buildQuizForLesson } from '../lib/quiz';

const allLessons = sortLessonEntries(loadLessons());

const modules = curriculumModules.map((module) => {
  const lessons = allLessons
    .filter((lesson) => lesson.data.moduleId === module.id)
    .map((lesson) => ({
      lesson,
      questions: buildQuizForLesson(lesson, allLessons),
    }));

  return { ...module, lessons };
});

const totalQuestions = modules.reduce(
  (count, module) =>
    count + module.lessons.reduce((moduleCount, lesson) => moduleCount + lesson.questions.length, 0),
  0,
);
---

<BaseLayout
  title="Quiz Center | English Grammar Atlas"
  description="Practice every lesson with structured quizzes built from the lesson content."
>
  <main class="main-content">
    <div class="container">
      <section class="quiz-home-hero">
        <div class="quiz-home-hero-shell">
          <div class="quiz-home-topline">
            <div>
              <p class="eyebrow">Lesson Practice</p>
              <p class="quiz-home-breadcrumb">Quiz Center / Structured review</p>
            </div>
            <a href="/dashboard" class="quiz-home-link">Open progress dashboard</a>
          </div>

          <div class="quiz-home-hero-content">
            <h1>Quiz Center</h1>
            <p class="hero-copy">
              Every lesson now has its own content-based quiz. Use the module sections below
              to move lesson by lesson, review what you studied, and keep your practice in
              curriculum order.
            </p>
          </div>

          <div class="hero-stats">
            <article class="hero-stat">
              <span class="hero-stat-label">Lesson quizzes</span>
              <strong>{allLessons.length}</strong>
              <span class="hero-stat-copy">one practice set for each lesson chapter</span>
            </article>
            <article class="hero-stat">
              <span class="hero-stat-label">Practice questions</span>
              <strong>{totalQuestions}</strong>
              <span class="hero-stat-copy">built from examples, rules, and corrections</span>
            </article>
            <article class="hero-stat">
              <span class="hero-stat-label">Standard set</span>
              <strong>10</strong>
              <span class="hero-stat-copy">questions per lesson for focused review</span>
            </article>
          </div>
        </div>
      </section>

      <section class="quiz-home-guide">
        <div class="guide-card">
          <p class="card-kicker">Start Here</p>
          <h2>How to use this</h2>
          <p>
            Finish a lesson, open its quiz, answer all questions, then review the feedback.
            Scores are saved in your browser for each lesson.
          </p>
        </div>
        <div class="guide-card">
          <p class="card-kicker">What Changed</p>
          <h2>What changed</h2>
          <p>
            The quiz routes are now connected to real lesson content instead of generic
            placeholder questions, and the lessons are back in curriculum order.
          </p>
        </div>
        <div class="guide-card">
          <p class="card-kicker">Stay On Track</p>
          <h2>Use the dashboard too</h2>
          <p>
            Your saved best scores, bookmarks, and completed lessons flow into the dashboard so you can see what to review next.
          </p>
        </div>
      </section>

      <section class="quiz-modules">
        {modules.map((module) => (
          <article class="module-block">
            <div class="module-block-header">
              <div class="module-heading">
                <p class="module-kicker">{module.level}</p>
                <h2>{module.title}</h2>
                <p class="module-lesson-count">{module.lessons.length} lesson quizzes in this module</p>
              </div>
              <div class="module-description-card">
                <p class="module-description">{module.description}</p>
              </div>
            </div>

            <div class="quiz-lesson-grid">
              {module.lessons.map(({ lesson, questions }) => (
                <article class="quiz-lesson-card">
                  <p class="card-kicker">Lesson quiz</p>
                  <div class="quiz-lesson-topline">
                    <span class="lesson-duration">{lesson.data.duration}</span>
                    <span class="lesson-count">{questions.length} questions</span>
                  </div>
                  <h3>{lesson.data.title}</h3>
                  <p>{lesson.data.focus}</p>
                  <div class="quiz-lesson-actions">
                    <a href={`/quiz/${lesson.data.slug}`} class="btn btn-primary">Start Quiz</a>
                    <a href={`/lessons/${lesson.data.slug}`} class="btn btn-secondary">View Lesson</a>
                  </div>
                </article>
              ))}
            </div>
          </article>
        ))}
      </section>
    </div>
  </main>

  <style>
    .quiz-home-hero {
      margin-bottom: var(--space-2xl);
    }

    .quiz-home-hero-shell {
      display: grid;
      grid-template-columns: minmax(0, 1.3fr) minmax(260px, 0.9fr);
      gap: 1.35rem 2rem;
      padding: clamp(1.8rem, 4vw, 3rem);
      border-radius: 1.5rem;
      position: relative;
      overflow: hidden;
      background:
        radial-gradient(circle at top left, rgba(243, 214, 172, 0.18), transparent 18rem),
        radial-gradient(circle at bottom right, rgba(63, 92, 82, 0.12), transparent 22rem),
        linear-gradient(145deg, rgba(255, 255, 255, 0.98), rgba(247, 242, 232, 0.95));
      border: 1px solid rgba(24, 34, 48, 0.08);
      box-shadow: 0 30px 60px -38px rgba(24, 34, 48, 0.34);
    }

    .quiz-home-hero-shell::after {
      content: '';
      position: absolute;
      inset: auto 0 0;
      height: 8px;
      background: linear-gradient(90deg, rgba(63, 92, 82, 0.78), rgba(201, 111, 50, 0.7));
      opacity: 0.24;
    }

    .quiz-home-topline {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
      grid-column: 1 / -1;
    }

    .eyebrow {
      font-family: var(--font-ui);
      letter-spacing: 0.08em;
      font-size: 0.78rem;
      font-weight: var(--font-weight-semibold);
      color: var(--color-accent);
      margin-bottom: 0.25rem;
      text-transform: uppercase;
    }

    .quiz-home-breadcrumb {
      margin: 0;
      font-family: var(--font-ui);
      font-size: 0.9rem;
      color: var(--color-text-secondary);
      letter-spacing: 0.01em;
    }

    .quiz-home-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.8rem;
      padding: 0.7rem 0.95rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.76);
      color: var(--color-primary-dark);
      font-family: var(--font-ui);
      font-weight: var(--font-weight-semibold);
      text-decoration: none;
      border: 1px solid rgba(24, 34, 48, 0.08);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.74);
      transition:
        transform var(--transition-base),
        background-color var(--transition-base),
        box-shadow var(--transition-base);
    }

    .quiz-home-link:hover {
      transform: translateY(-1px);
      background: white;
      box-shadow: var(--shadow-sm);
      text-decoration: none;
    }

    .quiz-home-hero-content {
      align-self: start;
    }

    .quiz-home-hero h1 {
      margin-top: 0;
      margin-bottom: 0.95rem;
      font-size: clamp(2.6rem, 5vw, 4.1rem);
      color: var(--color-primary-dark);
      max-width: 10ch;
      text-wrap: balance;
    }

    .hero-copy {
      max-width: 40rem;
      color: var(--color-text-secondary);
      font-size: 1.06rem;
      line-height: 1.8;
      margin: 0;
      text-wrap: balance;
    }

    .hero-stats {
      display: grid;
      align-content: start;
      gap: 0.85rem;
    }

    .hero-stat {
      display: grid;
      gap: 0.18rem;
      padding: 1rem 1.05rem;
      background: rgba(255, 255, 255, 0.76);
      border: 1px solid rgba(24, 34, 48, 0.08);
      border-radius: 1.1rem;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.72);
    }

    .hero-stat-label {
      font-family: var(--font-ui);
      font-size: 0.72rem;
      font-weight: var(--font-weight-semibold);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-accent);
    }

    .hero-stat strong {
      display: block;
      font-size: 1.65rem;
      color: var(--color-primary-dark);
      margin-bottom: 0.12rem;
    }

    .hero-stat-copy {
      color: var(--color-text-secondary);
      font-size: 0.92rem;
      line-height: 1.55;
    }

    .quiz-home-guide {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: var(--space-lg);
      margin-bottom: var(--space-2xl);
    }

    .guide-card {
      display: grid;
      gap: 0.75rem;
      padding: 1.45rem;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(249, 245, 238, 0.94));
      border: 1px solid rgba(24, 34, 48, 0.08);
      border-radius: 1.2rem;
      box-shadow: 0 22px 40px -34px rgba(24, 34, 48, 0.36);
      position: relative;
      overflow: hidden;
    }

    .guide-card::before {
      content: '';
      position: absolute;
      inset: 0 auto 0 0;
      width: 5px;
      background: linear-gradient(180deg, rgba(63, 92, 82, 0.92), rgba(201, 111, 50, 0.88));
      opacity: 0.75;
    }

    .card-kicker {
      margin: 0;
      color: var(--color-accent);
      font-family: var(--font-ui);
      font-size: 0.76rem;
      font-weight: var(--font-weight-semibold);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .guide-card h2 {
      margin-top: 0;
      margin-bottom: 0;
      font-size: 1.28rem;
      color: var(--color-primary-dark);
    }

    .guide-card p {
      margin: 0;
      color: var(--color-text-secondary);
      line-height: 1.65;
    }

    .guide-card .card-kicker,
    .quiz-lesson-card .card-kicker {
      color: var(--color-accent);
      line-height: 1.2;
    }

    .quiz-modules {
      display: grid;
      gap: var(--space-2xl);
    }

    .module-block {
      padding: 1.65rem;
      border: 1px solid rgba(24, 34, 48, 0.08);
      border-radius: 1.4rem;
      background:
        radial-gradient(circle at top right, rgba(201, 111, 50, 0.08), transparent 12rem),
        linear-gradient(180deg, rgba(255, 255, 255, 0.97), rgba(248, 245, 238, 0.92) 42%, #fff);
      box-shadow: 0 26px 48px -38px rgba(24, 34, 48, 0.34);
    }

    .module-block-header {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(280px, 380px);
      gap: var(--space-lg);
      align-items: start;
      margin-bottom: 1.4rem;
    }

    .module-heading {
      display: grid;
      gap: 0.45rem;
    }

    .module-kicker {
      margin-bottom: 0;
      color: var(--color-accent);
      font-family: var(--font-ui);
      font-size: 0.78rem;
      font-weight: var(--font-weight-semibold);
      letter-spacing: 0.07em;
      text-transform: uppercase;
    }

    .module-block-header h2 {
      margin: 0;
      font-size: clamp(1.7rem, 1.55rem + 0.4vw, 2rem);
      color: var(--color-primary-dark);
    }

    .module-lesson-count {
      margin: 0;
      font-family: var(--font-ui);
      font-size: 0.94rem;
      color: var(--color-text-secondary);
    }

    .module-description-card {
      padding: 1rem 1.05rem;
      border-radius: 1.05rem;
      background: rgba(255, 255, 255, 0.72);
      border: 1px solid rgba(24, 34, 48, 0.08);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.72);
    }

    .module-description {
      margin: 0;
      color: var(--color-text-secondary);
      line-height: 1.65;
    }

    .quiz-lesson-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: var(--space-lg);
    }

    .quiz-lesson-card {
      display: flex;
      flex-direction: column;
      gap: 0.9rem;
      padding: 1.35rem;
      border-radius: 1.15rem;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(250, 247, 241, 0.95));
      border: 1px solid rgba(24, 34, 48, 0.08);
      box-shadow: 0 20px 34px -32px rgba(24, 34, 48, 0.34);
      transition:
        transform var(--transition-base),
        box-shadow var(--transition-base),
        border-color var(--transition-base);
      position: relative;
      overflow: hidden;
    }

    .quiz-lesson-card::before {
      content: '';
      position: absolute;
      inset: 0 auto 0 0;
      width: 4px;
      background: linear-gradient(180deg, rgba(63, 92, 82, 0.9), rgba(201, 111, 50, 0.9));
      opacity: 0.76;
    }

    .quiz-lesson-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 28px 44px -32px rgba(24, 34, 48, 0.38);
      border-color: rgba(63, 92, 82, 0.16);
    }

    .quiz-lesson-topline {
      display: flex;
      justify-content: space-between;
      gap: 0.75rem;
      flex-wrap: wrap;
      font-size: 0.82rem;
      color: var(--color-text-secondary);
    }

    .lesson-duration,
    .lesson-count {
      padding: 0.35rem 0.7rem;
      border-radius: 999px;
      background: rgba(247, 242, 232, 0.94);
      font-family: var(--font-ui);
      font-size: 0.78rem;
      font-weight: var(--font-weight-semibold);
    }

    .quiz-lesson-card h3 {
      margin: 0;
      font-size: 1.22rem;
      color: var(--color-primary-dark);
    }

    .quiz-lesson-card p {
      margin: 0;
      color: var(--color-text-secondary);
      line-height: 1.6;
      flex: 1;
    }

    .quiz-lesson-actions {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    @media (max-width: 900px) {
      .quiz-home-hero-shell,
      .module-block-header {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 768px) {
      .quiz-home-hero-shell,
      .module-block {
        padding: 1.25rem;
      }

      .quiz-lesson-actions {
        flex-direction: column;
      }

      .quiz-lesson-actions .btn {
        width: 100%;
      }

      .hero-stats {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
