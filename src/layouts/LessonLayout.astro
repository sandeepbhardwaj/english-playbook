---
import BaseLayout from './BaseLayout.astro';
import type { LessonNavigationItem } from '../lib/course';

interface Props {
  title: string;
  slug: string;
  module: string;
  moduleId: string;
  duration: string;
  focus: string;
  level: string;
  previousLesson?: LessonNavigationItem;
  nextLesson?: LessonNavigationItem;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const { title, slug, module, moduleId, duration, focus, level, previousLesson, nextLesson, structuredData } = Astro.props;
---

<BaseLayout title={`${title} | English Grammar Atlas`} description={focus} structuredData={structuredData}>
  <article class:list={['lesson', `lesson--${slug}`]} data-lesson-slug={slug}>
    <!-- Hero Section -->
    <section class="lesson-hero">
      <div class="container">
        <div class="lesson-hero-shell">
          <div class="lesson-hero-topline">
            <p class="lesson-kicker">Lesson in {module}</p>
            <div class="lesson-hero-actions">
              <a href={`/modules/${moduleId}`} class="lesson-hero-module-link">Open module overview</a>
              <button type="button" class="lesson-hero-print" data-lesson-print-trigger>Print lesson</button>
            </div>
          </div>

          <div class="lesson-hero-content">
            <h1>{title}</h1>
            <p class="lesson-focus-copy page-subheading">{focus}</p>
          </div>

          <div class="lesson-meta">
            <div class="lesson-meta-item">
              <span class="lesson-meta-label">Module</span>
              <strong>{module}</strong>
            </div>
            <div class="lesson-meta-item">
              <span class="lesson-meta-label">Estimated time</span>
              <strong>{duration}</strong>
            </div>
            <div class="lesson-meta-item">
              <span class="lesson-meta-label">Level</span>
              <strong>{level}</strong>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Main Content -->
    <div class="container">
      <div class="lesson-content">
        <!-- Main Content -->
        <main class="content-prose">
          <slot />
        </main>
      </div>
    </div>

    {(previousLesson || nextLesson) && (
      <section class="lesson-navigation-shell">
        <div class="container">
          <div class="lesson-navigation-header">
            <p class="lesson-navigation-kicker">Keep moving through the curriculum</p>
            <a href={`/modules/${moduleId}`} class="lesson-module-link">Back to {module}</a>
          </div>
          <div class="lesson-navigation-grid">
            {previousLesson ? (
              <a href={previousLesson.href} class="lesson-navigation-card previous">
                <span class="lesson-navigation-topline">
                  <span class="lesson-navigation-arrow" aria-hidden="true">←</span>
                  <span class="lesson-navigation-label">Previous lesson</span>
                </span>
                <strong>{previousLesson.title}</strong>
                <span>{previousLesson.focus}</span>
              </a>
            ) : (
              <a href="/curriculum" class="lesson-navigation-card fallback">
                <span class="lesson-navigation-topline">
                  <span class="lesson-navigation-arrow" aria-hidden="true">↺</span>
                  <span class="lesson-navigation-label">Start of path</span>
                </span>
                <strong>View the full curriculum</strong>
                <span>Return to the course map and choose where to continue next.</span>
              </a>
            )}

            {nextLesson ? (
              <a href={nextLesson.href} class="lesson-navigation-card next">
                <span class="lesson-navigation-topline">
                  <span class="lesson-navigation-label">Next lesson</span>
                  <span class="lesson-navigation-arrow" aria-hidden="true">→</span>
                </span>
                <strong>{nextLesson.title}</strong>
                <span>{nextLesson.focus}</span>
              </a>
            ) : (
              <a href="/quiz/final-review" class="lesson-navigation-card fallback">
                <span class="lesson-navigation-topline">
                  <span class="lesson-navigation-arrow" aria-hidden="true">✓</span>
                  <span class="lesson-navigation-label">You reached the end</span>
                </span>
                <strong>Take the final review quiz</strong>
                <span>Wrap up the course with the closing practice set and check retention.</span>
              </a>
            )}
          </div>
        </div>
      </section>
    )}

    <!-- Next Steps Section -->
    <section class="lesson-next-steps">
      <div class="container">
        <div class="next-steps-content">
          <div class="next-step-card practice">
            <p class="card-kicker">Lesson Practice</p>
            <h3>Ready to Practice?</h3>
            <p>Reinforce your understanding with targeted exercises and quizzes designed specifically for this lesson.</p>
            <a href={`/quiz/${slug}`} class="btn btn-primary btn-lg">Start Practice Exercises</a>
          </div>

          <div class="next-step-card track" data-lesson-progress data-lesson-slug={slug}>
            <p class="card-kicker">Study Progress</p>
            <h3>Track Progress</h3>
            <p class="progress-copy">Mark this lesson complete when you finish it so the dashboard can build a real review plan.</p>
            <div class="step-buttons">
              <button type="button" class="btn btn-outline lesson-progress-toggle">Mark Lesson Complete</button>
              <button type="button" class="btn btn-outline lesson-bookmark-toggle">Add Bookmark</button>
              <a href="/dashboard" class="btn btn-outline">Open Dashboard</a>
            </div>
          </div>
          
          <div class="next-step-card explore">
            <p class="card-kicker">Keep Exploring</p>
            <h3>Explore Your Path</h3>
            <p>View the complete curriculum or follow the structured roadmap to stay on track with your learning journey.</p>
            <div class="step-buttons">
              <a href="/curriculum" class="btn btn-outline">View Curriculum</a>
              <a href="/roadmap" class="btn btn-outline">Study Roadmap</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </article>

  <style>
    .lesson {
      background-color: var(--color-background);
    }

    .lesson-hero {
      background:
        radial-gradient(circle at top right, rgba(243, 214, 172, 0.2), transparent 24rem),
        radial-gradient(circle at top left, rgba(52, 116, 93, 0.1), transparent 22rem),
        linear-gradient(180deg, rgba(248, 243, 234, 0.97), rgba(255, 255, 255, 0.12));
      padding: 1.65rem 0 1.05rem;
      margin-bottom: 2.35rem;
    }

    .lesson-hero-shell {
      max-width: 1080px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: minmax(0, 1.45fr) minmax(240px, 0.7fr);
      gap: 1.35rem 2rem;
      padding: clamp(1.7rem, 4vw, 2.8rem);
      border-radius: 1.5rem;
      overflow: hidden;
      position: relative;
      background:
        radial-gradient(circle at top right, rgba(243, 214, 172, 0.22), transparent 15rem),
        radial-gradient(circle at bottom left, rgba(63, 92, 82, 0.1), transparent 18rem),
        linear-gradient(145deg, rgba(255, 255, 255, 0.99), rgba(249, 244, 236, 0.97));
      border: 1px solid rgba(24, 34, 48, 0.08);
      box-shadow: 0 30px 60px -38px rgba(24, 34, 48, 0.34);
      color: var(--color-text);
    }

    .lesson-hero-shell::after {
      content: '';
      position: absolute;
      inset: auto 0 0;
      height: 8px;
      background: linear-gradient(90deg, rgba(63, 92, 82, 0.78), rgba(201, 111, 50, 0.7));
      opacity: 0.26;
    }

    .lesson-hero-topline {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      grid-column: 1 / -1;
      margin-bottom: 0.1rem;
      flex-wrap: wrap;
    }

    .lesson-kicker {
      margin: 0;
      color: var(--color-accent);
      font-family: var(--font-ui);
      font-size: 0.84rem;
      font-weight: var(--font-weight-semibold);
      letter-spacing: 0.09em;
      text-transform: uppercase;
    }

    .lesson-hero-content {
      align-self: start;
      padding-right: 0.5rem;
    }

    .lesson-hero-content h1 {
      color: var(--color-primary-dark);
      margin-bottom: 0.82rem;
      font-size: clamp(2.8rem, 5vw, 4.2rem);
      line-height: 1.04;
      max-width: 11ch;
      text-wrap: balance;
    }

    .lesson-meta {
      margin-top: 0;
      display: grid;
      grid-template-columns: 1fr;
      align-content: start;
      gap: 0.7rem;
      padding: 1.05rem;
      border-radius: 1.25rem;
      background: rgba(255, 255, 255, 0.74);
      border: 1px solid rgba(24, 34, 48, 0.08);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.72);
      backdrop-filter: blur(8px);
    }

    .lesson-meta-item {
      display: grid;
      gap: 0.12rem;
      min-width: 0;
      padding: 0.88rem 0.92rem;
      border-radius: 0.95rem;
      background: rgba(255, 255, 255, 0.84);
      border: 1px solid rgba(24, 34, 48, 0.06);
    }

    .lesson-meta-label {
      color: var(--color-text-secondary);
      font-family: var(--font-ui);
      font-size: 0.78rem;
      font-weight: var(--font-weight-semibold);
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    .lesson-meta-item strong {
      color: var(--color-primary-dark);
      font-size: 0.98rem;
      font-weight: var(--font-weight-semibold);
    }

    .lesson-focus-copy {
      max-width: 40rem;
    }

    .lesson-hero-actions {
      display: inline-flex;
      align-items: center;
      justify-content: flex-end;
      flex-wrap: wrap;
      gap: 0.7rem;
    }

    .lesson-hero-module-link,
    .lesson-hero-print {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.8rem;
      padding: 0.7rem 0.95rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.76);
      color: var(--color-primary-dark);
      font-family: var(--font-ui);
      font-size: 0.95rem;
      font-weight: var(--font-weight-semibold);
      text-decoration: none;
      transition:
        transform var(--transition-base),
        background-color var(--transition-base),
        box-shadow var(--transition-base);
      border: 1px solid rgba(24, 34, 48, 0.08);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.74);
    }

    .lesson-hero-print {
      cursor: pointer;
    }

    .lesson-hero-module-link:hover,
    .lesson-hero-print:hover {
      transform: translateY(-1px);
      background: white;
      box-shadow: var(--shadow-sm);
      text-decoration: none;
    }

    .lesson-hero-print:focus-visible {
      outline: 2px solid rgba(52, 116, 93, 0.28);
      outline-offset: 3px;
    }

    .lesson-content {
      width: 100%;
    }

    .lesson-navigation-shell {
      margin-top: 3rem;
    }

    .lesson-navigation-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin: 0 auto 1.25rem;
      max-width: 800px;
    }

    .lesson-navigation-kicker {
      margin: 0;
      color: var(--color-accent);
      font-family: var(--font-ui);
      font-size: 0.82rem;
      font-weight: var(--font-weight-semibold);
      letter-spacing: 0.04em;
    }

    .lesson-module-link {
      font-family: var(--font-ui);
      color: var(--color-primary);
      font-size: 0.95rem;
    }

    .lesson-navigation-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
      max-width: 800px;
      margin: 0 auto;
    }

    .lesson-navigation-card {
      display: grid;
      gap: 0.6rem;
      padding: 1.35rem 1.45rem;
      border-radius: 1.15rem;
      border: 1px solid rgba(24, 34, 48, 0.08);
      background:
        linear-gradient(145deg, rgba(255, 255, 255, 0.94), rgba(247, 242, 232, 0.92));
      box-shadow: var(--shadow-sm);
      transition:
        transform var(--transition-base),
        box-shadow var(--transition-base),
        border-color var(--transition-base),
        background var(--transition-base);
    }

    .lesson-navigation-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
      border-color: rgba(52, 116, 93, 0.18);
      text-decoration: none;
    }

    .lesson-navigation-topline {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
    }

    .lesson-navigation-arrow {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 1.9rem;
      height: 1.9rem;
      border-radius: 999px;
      background: rgba(52, 116, 93, 0.1);
      color: var(--color-primary);
      font-family: var(--font-ui);
      font-size: 0.96rem;
      font-weight: var(--font-weight-semibold);
      flex-shrink: 0;
    }

    .lesson-navigation-card strong {
      color: var(--color-primary-dark);
      font-size: 1.14rem;
      line-height: 1.35;
      text-wrap: balance;
    }

    .lesson-navigation-card span:last-child {
      color: var(--color-text-secondary);
      line-height: 1.68;
    }

    .lesson-navigation-label {
      color: var(--color-accent);
      font-family: var(--font-ui);
      font-size: 0.78rem;
      font-weight: var(--font-weight-semibold);
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    .lesson-navigation-card.previous {
      background:
        linear-gradient(145deg, rgba(255, 255, 255, 0.95), rgba(243, 239, 231, 0.94));
    }

    .lesson-navigation-card.next {
      background:
        linear-gradient(145deg, rgba(245, 251, 247, 0.96), rgba(255, 248, 240, 0.94));
    }

    .lesson-navigation-card.fallback {
      background:
        linear-gradient(145deg, rgba(248, 245, 239, 0.96), rgba(255, 255, 255, 0.92));
    }

    /* Prose Content Styling */
    .content-prose {
      max-width: 800px;
      margin: 0 auto;
      line-height: 1.78;
      color: var(--color-text);
      font-size: clamp(1.03rem, 0.99rem + 0.16vw, 1.1rem);
    }

    .content-prose h2 {
      font-size: clamp(1.62rem, 1.45rem + 0.55vw, 1.9rem);
      color: #355046;
      margin: 2rem 0 1rem 0;
      font-weight: var(--font-weight-bold);
      border-bottom: 2px solid var(--color-border);
      padding-bottom: 0.5rem;
    }

    .content-prose h3 {
      font-size: clamp(1.28rem, 1.18rem + 0.3vw, 1.45rem);
      color: #5f776d;
      margin: 1.5rem 0 0.75rem 0;
      font-weight: var(--font-weight-semibold);
    }

    .content-prose h4 {
      font-size: 1.08rem;
      color: var(--color-text);
      margin: 1rem 0 0.5rem 0;
      font-weight: var(--font-weight-semibold);
    }

    .content-prose p {
      margin: 1rem 0;
      line-height: 1.82;
    }

    .content-prose ul,
    .content-prose ol {
      margin: 1.5rem 0;
      padding-left: 2rem;
    }

    .content-prose li {
      margin: 0.5rem 0;
      line-height: 1.82;
    }

    .content-prose li strong {
      color: var(--color-primary);
    }

    .content-prose strong,
    .content-prose b {
      color: var(--color-primary);
      font-weight: var(--font-weight-bold);
    }

    .content-prose em,
    .content-prose i {
      font-style: italic;
      color: var(--color-text-secondary);
    }

    .content-prose code {
      background-color: var(--color-bg-secondary);
      color: var(--color-primary);
      padding: 0.25rem 0.5rem;
      border-radius: var(--radius-sm);
      font-family: 'Courier New', monospace;
      font-size: 0.95em;
    }

    .content-prose pre {
      background-color: var(--color-bg-secondary);
      border-left: 4px solid var(--color-primary);
      padding: 1rem;
      border-radius: var(--radius-md);
      overflow-x: auto;
      margin: 1.5rem 0;
      line-height: 1.5;
    }

    .content-prose pre code {
      background: none;
      color: inherit;
      padding: 0;
      border-radius: 0;
    }

    .content-prose blockquote {
      border-left: 4px solid var(--color-primary);
      padding: 1rem 1rem 1rem 1.5rem;
      background-color: var(--color-surface);
      margin: 1.5rem 0;
      border-radius: var(--radius-md);
      font-style: italic;
      color: var(--color-text-secondary);
    }

    .content-prose a {
      color: var(--color-primary);
      text-decoration: underline;
      transition: opacity var(--transition-fast);
    }

    .content-prose a:hover {
      opacity: 0.8;
      text-decoration: none;
    }

    .content-prose table {
      width: 100%;
      border-collapse: collapse;
      margin: 1.5rem 0;
      border-radius: var(--radius-md);
      overflow: hidden;
    }

    .content-prose th {
      background-color: var(--color-primary);
      color: white;
      padding: 0.75rem;
      text-align: left;
      font-weight: var(--font-weight-bold);
    }

    .content-prose td {
      padding: 0.75rem;
      border-bottom: 1px solid var(--color-border);
    }

    .content-prose tr:last-child td {
      border-bottom: none;
    }

    .content-prose tr:nth-child(even) {
      background-color: var(--color-surface);
    }

    /* Special styling for lesson content patterns */
    .content-prose strong + em {
      display: block;
      margin: 0.5rem 0 1rem 0;
      padding-left: 1rem;
    }

    .lesson-markdown--chaptered {
      padding: clamp(1.35rem, 3.5vw, 2.3rem);
      border-radius: 1.6rem;
      background:
        radial-gradient(circle at top right, rgba(201, 111, 50, 0.12), transparent 12rem),
        radial-gradient(circle at top left, rgba(63, 92, 82, 0.08), transparent 14rem),
        linear-gradient(180deg, rgba(255, 255, 255, 0.99), rgba(249, 245, 237, 0.95));
      border: 1px solid rgba(24, 34, 48, 0.08);
      box-shadow: 0 24px 48px -32px rgba(24, 34, 48, 0.36);
    }

    .lesson-markdown--chaptered > :first-child {
      margin-top: 0;
    }

    .lesson-markdown--chaptered .lesson-heading {
      text-wrap: balance;
      scroll-margin-top: 1.2rem;
    }

    .lesson-markdown--chaptered .lesson-heading-chapter {
      margin: 2.4rem 0 1rem;
      padding: 1.1rem 1.15rem 0.95rem;
      border-radius: 1.1rem;
      border: 1px solid rgba(63, 92, 82, 0.16);
      border-left: 6px solid rgba(201, 111, 50, 0.92);
      background:
        linear-gradient(135deg, rgba(244, 247, 246, 0.98), rgba(255, 249, 242, 0.98));
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.78),
        0 10px 24px -24px rgba(24, 34, 48, 0.3);
      color: var(--color-primary-dark);
      font-size: clamp(1.52rem, 1.28rem + 0.58vw, 1.96rem);
      border-bottom: none;
    }

    .lesson-markdown--chaptered .lesson-heading-section {
      margin: 2.05rem 0 0.95rem;
      padding: 0.88rem 1rem 0.82rem 3.8rem;
      border-radius: 1rem;
      background:
        linear-gradient(90deg, rgba(63, 92, 82, 0.13), rgba(255, 255, 255, 0));
      border: 1px solid rgba(63, 92, 82, 0.12);
      color: #365046;
      font-size: clamp(1.24rem, 1.06rem + 0.38vw, 1.54rem);
      border-bottom: none;
      position: relative;
      box-shadow: 0 10px 22px -26px rgba(24, 34, 48, 0.28);
    }

    .lesson-markdown--chaptered .lesson-heading-section::before {
      content: attr(data-section-number);
      position: absolute;
      top: 50%;
      left: 1rem;
      transform: translateY(-50%);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 2rem;
      height: 2rem;
      border-radius: 999px;
      background: rgba(201, 111, 50, 0.16);
      color: var(--color-accent);
      font-family: var(--font-ui);
      font-size: 0.86rem;
      font-weight: var(--font-weight-bold);
      letter-spacing: 0;
    }

    .lesson-markdown--chaptered .lesson-heading-subsection {
      margin: 1.45rem 0 0.6rem;
      color: var(--color-primary-dark);
      font-family: var(--font-ui);
      font-size: clamp(1.02rem, 0.98rem + 0.12vw, 1.08rem);
      font-weight: var(--font-weight-semibold);
      letter-spacing: 0.01em;
      text-transform: none;
    }

    .lesson-markdown--chaptered .lesson-heading-feature {
      margin: 1.6rem 0 0.7rem;
      color: var(--color-primary-dark);
      font-size: clamp(1.22rem, 1.12rem + 0.28vw, 1.42rem);
      font-style: italic;
      line-height: 1.28;
    }

    .lesson-markdown--chaptered .lesson-heading-example {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      margin: 1.4rem 0 0.55rem;
      padding: 0.34rem 0.72rem;
      border-radius: 999px;
      background: rgba(63, 92, 82, 0.09);
      border: 1px solid rgba(63, 92, 82, 0.14);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.72);
      color: var(--color-primary-dark);
      font-family: var(--font-ui);
      font-size: 0.68rem;
      font-weight: var(--font-weight-semibold);
      letter-spacing: 0.09em;
      text-transform: uppercase;
    }

    .lesson-markdown--chaptered .lesson-example-list {
      margin-top: 0.35rem;
      padding: 0.95rem 1rem 0.95rem 1.3rem;
      border-radius: 1rem;
      background:
        linear-gradient(135deg, rgba(255, 255, 255, 0.99), rgba(245, 247, 241, 0.95));
      border: 1px solid rgba(63, 92, 82, 0.12);
      box-shadow: 0 16px 28px -28px rgba(24, 34, 48, 0.38);
    }

    .lesson-markdown--chaptered .lesson-list-label {
      margin-bottom: 0.55rem;
      color: var(--color-text-secondary);
      font-family: var(--font-ui);
      font-size: 0.78rem;
      font-weight: var(--font-weight-semibold);
      letter-spacing: 0.07em;
      text-transform: uppercase;
    }

    .lesson-markdown--chaptered .lesson-labeled-list {
      margin-top: 0.35rem;
      padding: 0.95rem 1rem 0.95rem 1.28rem;
      border-radius: 1rem;
      background: rgba(244, 247, 246, 0.8);
      border: 1px solid rgba(24, 34, 48, 0.07);
      box-shadow: 0 14px 26px -30px rgba(24, 34, 48, 0.32);
    }

    .lesson-markdown--chaptered .lesson-labeled-list-ol {
      list-style: none;
      margin-top: 0.35rem;
      margin-left: 0;
      padding: 0;
      counter-reset: article-step;
      display: grid;
      gap: 0.8rem;
    }

    .lesson-markdown--chaptered .lesson-labeled-list-ol > li {
      position: relative;
      margin: 0;
      padding: 0.9rem 1rem 0.9rem 3rem;
      border-radius: 1rem;
