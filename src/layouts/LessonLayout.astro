        padding: 0.9rem 0.95rem 0.82rem;
      }

      .lesson-markdown--chaptered .lesson-heading-section {
        padding: 0.72rem 0.85rem 0.7rem 3.3rem;
      }

      .lesson-markdown--chaptered .lesson-heading-example {
