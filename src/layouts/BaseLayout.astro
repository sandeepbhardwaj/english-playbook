---
import '../assets/css/global.css';
import '../assets/css/layout.css';
import '../assets/css/components.css';

import BackToTopButton from '../components/layout/BackToTopButton.astro';
import SiteFooter from '../components/layout/SiteFooter.astro';
import SiteHeader from '../components/layout/SiteHeader.astro';
import { BRAND_SUBTITLE, SITE_NAME, buildPrimaryNavigation } from '../lib/site';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title = SITE_NAME,
  description = BRAND_SUBTITLE,
  canonical = Astro.url.href,
  ogImage = '/site-og.png?v=20260405',
  ogType = 'website',
  noindex = false,
  structuredData,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://english.scalemind.dev';
const canonicalUrl = new URL(canonical, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();
const ogImageType = ogImage.includes('.png') ? 'image/png' : ogImage.includes('.svg') ? 'image/svg+xml' : undefined;
const usesDefaultOgImage = ogImage.startsWith('/site-og.png');
const faviconVersion = '20260405';
const robotsContent = noindex
  ? 'noindex,follow,max-image-preview:large'
  : 'index,follow,max-image-preview:large';
const currentPath = new URL(Astro.request.url).pathname;
const navigation = buildPrimaryNavigation(currentPath);

const schemaItems = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE_NAME,
    url: siteUrl,
    description: BRAND_SUBTITLE,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: SITE_NAME,
    url: siteUrl,
    logo: new URL('/favicon.svg', siteUrl).toString(),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: title,
    description,
    url: canonicalUrl,
    isPartOf: {
      '@type': 'WebSite',
      name: SITE_NAME,
      url: siteUrl,
    },
    primaryImageOfPage: {
      '@type': 'ImageObject',
      url: ogImageUrl,
    },
  },
  ...(Array.isArray(structuredData) ? structuredData : structuredData ? [structuredData] : []),
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content={robotsContent} />
    <meta name="theme-color" content="#3d564b" />

    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    {ogImageType && <meta property="og:image:type" content={ogImageType} />}
    {usesDefaultOgImage && <meta property="og:image:width" content="1200" />}
    {usesDefaultOgImage && <meta property="og:image:height" content="630" />}
    <meta property="og:image:alt" content="English Grammar Atlas study portal preview" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href={`/favicon.svg?v=${faviconVersion}`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`/favicon-32.png?v=${faviconVersion}`} />
    <link rel="shortcut icon" href={`/favicon.ico?v=${faviconVersion}`} />
    <link rel="apple-touch-icon" href={`/apple-touch-icon.png?v=${faviconVersion}`} />

    <script is:inline src="/scripts/progress.js"></script>
    {schemaItems.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
  </head>

  <body>
    <div class="layout">
      <SiteHeader brandSubtitle={BRAND_SUBTITLE} navigation={navigation} />

      <main class="layout-main">
        <slot />
      </main>

      <SiteFooter brandSubtitle={BRAND_SUBTITLE} />
      <BackToTopButton />
    </div>

    <script>
      import { initBaseLayout } from '../scripts/base-layout';

      initBaseLayout();
    </script>
  </body>
</html>
