---
import '../assets/css/global.css';
import '../assets/css/layout.css';
import '../assets/css/components.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title = 'English Grammar Atlas',
  description = 'Master English grammar from foundations to advanced proficiency',
  canonical = Astro.url.href,
  ogImage = '/site-og.png?v=20260405',
  ogType = 'website',
  noindex = false,
  structuredData,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://english.scalemind.dev';
const canonicalUrl = new URL(canonical, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();
const ogImageType = ogImage.includes('.png') ? 'image/png' : ogImage.includes('.svg') ? 'image/svg+xml' : undefined;
const usesDefaultOgImage = ogImage.startsWith('/site-og.png');
const faviconVersion = '20260405';
const robotsContent = noindex
  ? 'noindex,follow,max-image-preview:large'
  : 'index,follow,max-image-preview:large';
const currentPath = new URL(Astro.request.url).pathname;
const navigation = [
  { href: '/', label: 'Home' },
  { href: '/curriculum', label: 'Curriculum' },
  { href: '/roadmap', label: 'Roadmap' },
  { href: '/dashboard', label: 'Dashboard' },
  { href: '/quiz', label: 'Quiz' },
].map((item) => ({
  ...item,
  isActive:
    item.href === '/'
      ? currentPath === '/'
      : currentPath === item.href || currentPath.startsWith(`${item.href}/`),
}));

const schemaItems = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'English Grammar Atlas',
    url: siteUrl,
    description: 'Structured English grammar lessons, quizzes, and roadmap-based study flow.',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'English Grammar Atlas',
    url: siteUrl,
    logo: new URL('/favicon.svg', siteUrl).toString(),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: title,
    description,
    url: canonicalUrl,
    isPartOf: {
      '@type': 'WebSite',
      name: 'English Grammar Atlas',
      url: siteUrl,
    },
    primaryImageOfPage: {
      '@type': 'ImageObject',
      url: ogImageUrl,
    },
  },
  ...(Array.isArray(structuredData) ? structuredData : structuredData ? [structuredData] : []),
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content={robotsContent} />
    <meta name="theme-color" content="#3d564b" />

    <meta property="og:site_name" content="English Grammar Atlas" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    {ogImageType && <meta property="og:image:type" content={ogImageType} />}
    {usesDefaultOgImage && <meta property="og:image:width" content="1200" />}
    {usesDefaultOgImage && <meta property="og:image:height" content="630" />}
    <meta property="og:image:alt" content="English Grammar Atlas study portal preview" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`/favicon.svg?v=${faviconVersion}`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`/favicon-32.png?v=${faviconVersion}`} />
    <link rel="shortcut icon" href={`/favicon.ico?v=${faviconVersion}`} />
    <link rel="apple-touch-icon" href={`/apple-touch-icon.png?v=${faviconVersion}`} />
    <script is:inline src="/scripts/progress.js"></script>
    {schemaItems.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
  </head>
  <body>
    <div class="layout">
      <header class="header">
        <div class="container">
          <div class="flex-between site-header-row">
            <a href="/" class="site-brand" aria-label="English Grammar Atlas home">
              <span class="site-brand-mark">GA</span>
              <span class="site-brand-copy">
                <strong>English Grammar Atlas</strong>
                <span>Lessons, quizzes, and roadmap</span>
              </span>
            </a>
            <nav class="site-nav site-nav-desktop" aria-label="Primary">
              {navigation.map((item) => (
                <a
                  href={item.href}
                  class:list={['site-nav-link', item.href === '/quiz' && 'btn btn-primary', item.isActive && 'is-active']}
                  aria-current={item.isActive ? 'page' : undefined}
                >
                  {item.label}
                </a>
              ))}
            </nav>
            <button
              type="button"
              class="site-nav-toggle"
              aria-label="Toggle navigation"
              aria-controls="mobile-nav"
              aria-expanded="false"
              data-mobile-nav-toggle
            >
              <span class="site-nav-toggle-bar"></span>
              <span class="site-nav-toggle-bar"></span>
              <span class="site-nav-toggle-bar"></span>
            </button>
          </div>
          <nav id="mobile-nav" class="site-nav-mobile-panel" aria-label="Primary" data-mobile-nav>
            {navigation.map((item) => (
              <a
                href={item.href}
                class:list={['site-nav-link', item.href === '/quiz' && 'btn btn-primary', item.isActive && 'is-active']}
                aria-current={item.isActive ? 'page' : undefined}
              >
                {item.label}
              </a>
            ))}
          </nav>
        </div>
      </header>

      <main class="layout-main">
        <slot />
      </main>

      <footer class="footer">
        <div class="container">
          <div class="footer-grid">
            <div>
              <h4 class="footer-title">Study English with structure</h4>
              <p class="footer-copy">
                Grammar lessons, lesson-specific quizzes, and a roadmap that keeps the
                whole course connected.
              </p>
              <p class="footer-meta">Built for self-paced grammar practice.</p>
            </div>
            <div>
              <h4 class="footer-title">Explore</h4>
              <ul class="footer-links">
                <li><a href="/">Home</a></li>
                <li><a href="/curriculum">Curriculum</a></li>
                <li><a href="/roadmap">Roadmap</a></li>
                <li><a href="/dashboard">Dashboard</a></li>
                <li><a href="/quiz">Quiz Center</a></li>
              </ul>
            </div>
            <div>
              <h4 class="footer-title">Start Here</h4>
              <ul class="footer-links">
                <li><a href="/lessons/parts-of-speech">First Lesson</a></li>
                <li><a href="/modules/foundations">Foundations Module</a></li>
                <li><a href="/dashboard">Study Dashboard</a></li>
              </ul>
            </div>
          </div>
        </div>
      </footer>

      <button
        type="button"
        class="back-to-top"
        aria-label="Move to top"
        title="Move to top"
        data-back-to-top
      >
        <span aria-hidden="true">↑</span>
      </button>
    </div>

    <script is:inline>
      const mobileNavToggle = document.querySelector('[data-mobile-nav-toggle]');
      const mobileNav = document.querySelector('[data-mobile-nav]');
      const backToTopButton = document.querySelector('[data-back-to-top]');

      if (mobileNavToggle instanceof HTMLButtonElement && mobileNav instanceof HTMLElement) {
        const closeMobileNav = () => {
          mobileNav.classList.remove('is-open');
          mobileNavToggle.setAttribute('aria-expanded', 'false');
        };

        mobileNavToggle.addEventListener('click', () => {
          const isOpen = mobileNav.classList.toggle('is-open');
          mobileNavToggle.setAttribute('aria-expanded', String(isOpen));
        });

        mobileNav.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', closeMobileNav);
        });

        document.addEventListener('click', (event) => {
          if (!mobileNav.contains(event.target) && !mobileNavToggle.contains(event.target)) {
            closeMobileNav();
          }
        });

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') {
            closeMobileNav();
          }
        });

        window.addEventListener('resize', () => {
          if (window.innerWidth > 768) {
            closeMobileNav();
          }
        });
      }

      if (backToTopButton instanceof HTMLButtonElement) {
        const toggleBackToTop = () => {
          backToTopButton.classList.toggle('is-visible', window.scrollY > 420);
        };

        backToTopButton.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });

        toggleBackToTop();
        window.addEventListener('scroll', toggleBackToTop, { passive: true });
      }
    </script>
  </body>
</html>
