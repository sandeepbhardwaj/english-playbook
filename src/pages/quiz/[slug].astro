---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../assets/css/pages/lesson-quiz.css';
import { getModule, sortLessonEntries } from '../../lib/course';
import { loadLessons } from '../../lib/lesson-files';
import { buildQuizForLesson } from '../../lib/quiz';

export async function getStaticPaths() {
  const lessons = sortLessonEntries(await loadLessons());

  return lessons.map((lesson, index) => ({
    params: { slug: lesson.data.slug },
    props: {
      lesson,
      previousLesson: index > 0 ? lessons[index - 1] : undefined,
      nextLesson: index < lessons.length - 1 ? lessons[index + 1] : undefined,
    },
  }));
}

const lessons = sortLessonEntries(await loadLessons());
const {
  lesson,
  previousLesson,
  nextLesson,
} = Astro.props;

const moduleMeta = getModule(lesson.data.moduleId);
const quizQuestions = buildQuizForLesson(lesson, lessons);
const storageKey = `grammar-atlas.quiz.${lesson.data.slug}`;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://english.scalemind.dev';
const quizUrl = `${siteUrl}/quiz/${lesson.data.slug}`;
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'LearningResource',
    name: `${lesson.data.title} Quiz`,
    description: `Practice ${lesson.data.title} with a lesson-based quiz.`,
    url: quizUrl,
    learningResourceType: 'Quiz',
    educationalLevel: lesson.data.level || 'Beginner',
    isPartOf: {
      '@type': 'Course',
      name: 'English Grammar Atlas',
      url: siteUrl,
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: siteUrl,
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Quiz Center',
        item: `${siteUrl}/quiz`,
      },
      {
        '@type': 'ListItem',
        position: 3,
        name: lesson.data.title,
        item: quizUrl,
      },
    ],
  },
];
---

<BaseLayout
  title={`Quiz: ${lesson.data.title} | English Grammar Atlas`}
  description={`Practice ${lesson.data.title} with a lesson-based quiz.`}
  structuredData={structuredData}
>
  <main class="main-content lesson-quiz-page">
    <div class="container">
      <section class="quiz-hero">
        <div class="quiz-hero-shell">
          <div class="quiz-hero-topline">
            <div>
              <p class="quiz-eyebrow">Lesson Quiz</p>
              <p class="quiz-breadcrumb">
                <a href="/quiz">Quiz Center</a>
                <span>/</span>
                <a href={`/modules/${lesson.data.moduleId}`}>{moduleMeta?.title ?? lesson.data.module}</a>
                <span>/</span>
                <span>{lesson.data.title}</span>
              </p>
            </div>

            <div class="quiz-hero-links">
              <a href={`/lessons/${lesson.data.slug}`} class="quiz-hero-link">Review lesson chapter</a>
              <a href="/quiz" class="quiz-hero-link">Browse all quizzes</a>
            </div>
          </div>

          <div class="quiz-hero-content">
            <h1>{lesson.data.title}</h1>
            <p class="quiz-focus page-subheading">{lesson.data.focus}</p>
            <p class="quiz-hero-note">
              Answer every question, then use the explanations to review the exact rule,
              choice, or pattern that needs reinforcement.
            </p>
          </div>

          <div class="quiz-summary-card">
            <p class="quiz-card-kicker">Quiz Snapshot</p>
            <div class="summary-item">
              <span class="summary-label">Questions</span>
              <strong>{quizQuestions.length}</strong>
              <span class="summary-copy">one focused practice set for this lesson</span>
            </div>
            <div class="summary-item">
              <span class="summary-label">Lesson time</span>
              <strong>{lesson.data.duration}</strong>
              <span class="summary-copy">pair the quiz with the full chapter review</span>
            </div>
            <div class="summary-item">
              <span class="summary-label">Best saved score</span>
              <strong id="best-score-value">No score yet</strong>
              <span class="summary-copy">saved locally in your browser</span>
            </div>
          </div>
        </div>
      </section>

      <section class="quiz-support-grid">
        <article class="support-card">
          <p class="quiz-card-kicker">How To Use It</p>
          <h2>Before you submit</h2>
          <p>
            This quiz is built from the lesson examples, corrections, and key rules. Submit
            once you have answered every question to see explanations.
          </p>
        </article>
        <article class="support-card">
          <p class="quiz-card-kicker">Review Habit</p>
          <h2>Best way to learn from it</h2>
          <p>
            Treat missed answers as revision notes. Revisit the lesson chapter, compare the
            explanation with the original rule, then try the quiz again only after you can
            explain the correction in your own words.
          </p>
        </article>
        <article class="support-card">
          <p class="quiz-card-kicker">Quick Links</p>
          <h2>Helpful links</h2>
          <div class="support-links">
            <a href={`/lessons/${lesson.data.slug}`} class="btn btn-secondary">Back to Lesson</a>
            <a href="/dashboard" class="btn btn-secondary">Dashboard</a>
            <a href="/quiz" class="btn btn-secondary">All Quizzes</a>
          </div>
        </article>
      </section>

      <section class="quiz-panel" id="quiz-app" data-storage-key={storageKey}>
        <div class="quiz-panel-header">
          <div class="quiz-panel-copy">
            <p class="quiz-card-kicker">Practice Set</p>
            <h2>Answer all questions</h2>
            <p id="progress-copy">0 of {quizQuestions.length} answered</p>
          </div>

          <div class="quiz-progress-card">
            <span class="quiz-progress-label">Completion</span>
            <div class="progress-meter" aria-hidden="true">
              <span id="progress-bar"></span>
            </div>
          </div>
        </div>

        <div class="question-list">
          {quizQuestions.map((question, questionIndex) => (
            <article class="question-card" data-question-card={questionIndex}>
              <div class="question-heading">
                <span class="question-number">Question {questionIndex + 1}</span>
                <div class="question-chip-row">
                  {question.difficulty && <span class="question-difficulty">{question.difficulty}</span>}
                  <span class="question-tag">{question.tag}</span>
                </div>
              </div>
              <p class="question-prompt">{question.prompt}</p>

              <div class="option-list">
                {question.options.map((option, optionIndex) => (
                  <button
                    type="button"
                    class="option-button"
                    data-question-index={questionIndex}
                    data-option-index={optionIndex}
                  >
                    <span class="option-letter">{String.fromCharCode(65 + optionIndex)}</span>
                    <span>{option}</span>
                  </button>
                ))}
              </div>

              <p class="question-feedback" data-feedback hidden></p>
            </article>
          ))}
        </div>

        <div class="quiz-actions">
          <button type="button" class="btn btn-primary" id="submit-quiz">Submit Answers</button>
          <button type="button" class="btn btn-secondary" id="reset-quiz">Reset Quiz</button>
        </div>

        <div class="quiz-results" id="quiz-results" hidden>
          <h2>Your result</h2>
          <p id="results-summary"></p>
          <div class="quiz-card-actions">
            <a href="/dashboard" class="btn btn-secondary">Open Dashboard</a>
            <a href={`/lessons/${lesson.data.slug}`} class="btn btn-secondary">Review Lesson</a>
          </div>
        </div>
      </section>

      <section class="quiz-navigation">
        {previousLesson ? (
          <a href={`/quiz/${previousLesson.data.slug}`} class="quiz-nav-card previous">
            <span class="quiz-nav-topline">
              <span class="quiz-nav-arrow" aria-hidden="true">←</span>
              <span class="quiz-nav-label">Previous quiz</span>
            </span>
            <strong>{previousLesson.data.title}</strong>
            <span>{previousLesson.data.focus}</span>
          </a>
        ) : (
          <a href="/quiz" class="quiz-nav-card fallback">
            <span class="quiz-nav-topline">
              <span class="quiz-nav-arrow" aria-hidden="true">↺</span>
              <span class="quiz-nav-label">Quiz center</span>
            </span>
            <strong>Browse all lesson quizzes</strong>
            <span>Return to the full quiz index and choose any lesson to review.</span>
          </a>
        )}
        {nextLesson ? (
          <a href={`/quiz/${nextLesson.data.slug}`} class="quiz-nav-card next">
            <span class="quiz-nav-topline">
              <span class="quiz-nav-label">Next quiz</span>
              <span class="quiz-nav-arrow" aria-hidden="true">→</span>
            </span>
            <strong>{nextLesson.data.title}</strong>
            <span>{nextLesson.data.focus}</span>
          </a>
        ) : (
          <a href="/dashboard" class="quiz-nav-card fallback">
            <span class="quiz-nav-topline">
              <span class="quiz-nav-arrow" aria-hidden="true">✓</span>
              <span class="quiz-nav-label">Track progress</span>
            </span>
            <strong>Review your saved quiz scores</strong>
            <span>Open the dashboard to see strengths, weak spots, and what to revisit next.</span>
          </a>
        )}
      </section>
    </div>
  </main>

  <script type="application/json" id="quiz-data">
    {JSON.stringify(quizQuestions)}
  </script>

  <script>
    import { initLessonQuizPage } from '../../scripts/lesson-quiz-page';

    initLessonQuizPage();
  </script>
</BaseLayout>
