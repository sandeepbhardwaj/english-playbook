---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../assets/css/pages/dashboard.css';
import { curriculumModules, sortLessonEntries } from '../lib/course';
import { loadLessons } from '../lib/lesson-files';

const lessons = sortLessonEntries(await loadLessons()).map((lesson) => ({
  slug: lesson.data.slug,
  title: lesson.data.title,
  module: lesson.data.module,
  moduleId: lesson.data.moduleId,
  duration: lesson.data.duration,
  focus: lesson.data.focus,
}));

const modules = curriculumModules.map((module) => ({
  id: module.id,
  title: module.title,
  description: module.description,
  lessonSlugs: module.lessons.map((lesson) => lesson.id),
}));

const dashboardPayload = JSON.stringify({ lessons, modules });
---

<BaseLayout
  title="Dashboard | English Grammar Atlas"
  description="Track quiz scores, saved lessons, and review priorities in your browser-saved study dashboard."
  noindex={true}
>
  <main class="main-content dashboard-page">
    <div class="container">
      <section class="dashboard-hero">
        <div class="dashboard-hero-copy">
          <p class="dashboard-eyebrow">Study Command Center</p>
          <h1>Your learning dashboard</h1>
          <p>
            This page turns your saved quiz scores, lesson completions, bookmarks, and error log into a practical review loop. Everything stays in this browser unless you export it.
          </p>
        </div>
        <div class="dashboard-hero-actions">
          <a href="/curriculum" class="btn btn-primary">Browse Curriculum</a>
          <a href="/quiz" class="btn btn-secondary">Open Quiz Center</a>
        </div>
      </section>

      <section class="dashboard-metrics" id="dashboard-metrics"></section>

      <section class="dashboard-grid">
        <section class="dashboard-panel dashboard-command" id="dashboard-command"></section>
        <section class="dashboard-panel dashboard-review" id="dashboard-review"></section>
      </section>

      <section class="dashboard-panel" id="dashboard-modules"></section>
      <section class="dashboard-grid">
        <section class="dashboard-panel" id="dashboard-saved"></section>
        <section class="dashboard-panel" id="dashboard-tools"></section>
      </section>
      <section class="dashboard-panel" id="dashboard-errors"></section>
    </div>
  </main>

  <script type="application/json" id="dashboard-data" set:html={dashboardPayload}></script>

  <script>
    import { initDashboardPage } from '../scripts/dashboard-page';

    initDashboardPage();
  </script>
</BaseLayout>
