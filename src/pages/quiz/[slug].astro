---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getModule, sortLessonEntries } from '../../lib/course';
import { loadLessons } from '../../lib/lesson-files';
import { buildQuizForLesson } from '../../lib/quiz';

export function getStaticPaths() {
  const lessons = sortLessonEntries(loadLessons());

  return lessons.map((lesson, index) => ({
    params: { slug: lesson.data.slug },
    props: {
      lesson,
      previousLesson: index > 0 ? lessons[index - 1] : undefined,
      nextLesson: index < lessons.length - 1 ? lessons[index + 1] : undefined,
    },
  }));
}

const lessons = sortLessonEntries(loadLessons());
const {
  lesson,
  previousLesson,
  nextLesson,
} = Astro.props;

const moduleMeta = getModule(lesson.data.moduleId);
const quizQuestions = buildQuizForLesson(lesson, lessons);
const storageKey = `grammar-atlas.quiz.${lesson.data.slug}`;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://english.scalemind.dev';
const quizUrl = `${siteUrl}/quiz/${lesson.data.slug}`;
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'LearningResource',
    name: `${lesson.data.title} Quiz`,
    description: `Practice ${lesson.data.title} with a lesson-based quiz.`,
    url: quizUrl,
    learningResourceType: 'Quiz',
    educationalLevel: lesson.data.level || 'Beginner',
    isPartOf: {
      '@type': 'Course',
      name: 'English Grammar Atlas',
      url: siteUrl,
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: siteUrl,
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Quiz Center',
        item: `${siteUrl}/quiz`,
      },
      {
        '@type': 'ListItem',
        position: 3,
        name: lesson.data.title,
        item: quizUrl,
      },
    ],
  },
];
---

<BaseLayout
  title={`Quiz: ${lesson.data.title} | English Grammar Atlas`}
  description={`Practice ${lesson.data.title} with a lesson-based quiz.`}
  structuredData={structuredData}
>
  <main class="main-content">
    <div class="container">
      <section class="quiz-hero">
        <div class="quiz-hero-shell">
          <div class="quiz-hero-topline">
            <div>
              <p class="quiz-eyebrow">Lesson Quiz</p>
              <p class="quiz-breadcrumb">
                <a href="/quiz">Quiz Center</a>
                <span>/</span>
                <a href={`/modules/${lesson.data.moduleId}`}>{moduleMeta?.title ?? lesson.data.module}</a>
                <span>/</span>
                <span>{lesson.data.title}</span>
              </p>
            </div>

            <div class="quiz-hero-links">
              <a href={`/lessons/${lesson.data.slug}`} class="quiz-hero-link">Review lesson chapter</a>
              <a href="/quiz" class="quiz-hero-link">Browse all quizzes</a>
            </div>
          </div>

          <div class="quiz-hero-content">
            <h1>{lesson.data.title}</h1>
            <p class="quiz-focus">{lesson.data.focus}</p>
            <p class="quiz-hero-note">
              Answer every question, then use the explanations to review the exact rule,
              choice, or pattern that needs reinforcement.
            </p>
          </div>

          <div class="quiz-summary-card">
            <p class="card-kicker">Quiz Snapshot</p>
            <div class="summary-item">
              <span class="summary-label">Questions</span>
              <strong>{quizQuestions.length}</strong>
              <span class="summary-copy">one focused practice set for this lesson</span>
            </div>
            <div class="summary-item">
              <span class="summary-label">Lesson time</span>
              <strong>{lesson.data.duration}</strong>
              <span class="summary-copy">pair the quiz with the full chapter review</span>
            </div>
            <div class="summary-item">
              <span class="summary-label">Best saved score</span>
              <strong id="best-score-value">No score yet</strong>
              <span class="summary-copy">saved locally in your browser</span>
            </div>
          </div>
        </div>
      </section>

      <section class="quiz-support-grid">
        <article class="support-card">
          <p class="card-kicker">How To Use It</p>
          <h2>Before you submit</h2>
          <p>
            This quiz is built from the lesson examples, corrections, and key rules. Submit
            once you have answered every question to see explanations.
          </p>
        </article>
        <article class="support-card">
          <p class="card-kicker">Review Habit</p>
          <h2>Best way to learn from it</h2>
          <p>
            Treat missed answers as revision notes. Revisit the lesson chapter, compare the
            explanation with the original rule, then try the quiz again only after you can
            explain the correction in your own words.
          </p>
        </article>
        <article class="support-card">
          <p class="card-kicker">Quick Links</p>
          <h2>Helpful links</h2>
          <div class="support-links">
            <a href={`/lessons/${lesson.data.slug}`} class="btn btn-secondary">Back to Lesson</a>
            <a href="/dashboard" class="btn btn-secondary">Dashboard</a>
            <a href="/quiz" class="btn btn-secondary">All Quizzes</a>
          </div>
        </article>
      </section>

      <section class="quiz-panel" id="quiz-app" data-storage-key={storageKey}>
        <div class="quiz-panel-header">
          <div class="quiz-panel-copy">
            <p class="card-kicker">Practice Set</p>
            <h2>Answer all questions</h2>
            <p id="progress-copy">0 of {quizQuestions.length} answered</p>
          </div>

          <div class="quiz-progress-card">
            <span class="quiz-progress-label">Completion</span>
            <div class="progress-meter" aria-hidden="true">
              <span id="progress-bar"></span>
            </div>
          </div>
        </div>

        <div class="question-list">
          {quizQuestions.map((question, questionIndex) => (
            <article class="question-card" data-question-card={questionIndex}>
              <div class="question-heading">
                <span class="question-number">Question {questionIndex + 1}</span>
                <div class="question-chip-row">
                  {question.difficulty && <span class="question-difficulty">{question.difficulty}</span>}
                  <span class="question-tag">{question.tag}</span>
                </div>
              </div>
              <p class="question-prompt">{question.prompt}</p>

              <div class="option-list">
                {question.options.map((option, optionIndex) => (
                  <button
                    type="button"
                    class="option-button"
                    data-question-index={questionIndex}
                    data-option-index={optionIndex}
                  >
                    <span class="option-letter">{String.fromCharCode(65 + optionIndex)}</span>
                    <span>{option}</span>
                  </button>
                ))}
              </div>

              <p class="question-feedback" data-feedback hidden></p>
            </article>
          ))}
        </div>

        <div class="quiz-actions">
          <button type="button" class="btn btn-primary" id="submit-quiz">Submit Answers</button>
          <button type="button" class="btn btn-secondary" id="reset-quiz">Reset Quiz</button>
        </div>

        <div class="quiz-results" id="quiz-results" hidden>
          <h2>Your result</h2>
          <p id="results-summary"></p>
          <div class="card-actions">
            <a href="/dashboard" class="btn btn-secondary">Open Dashboard</a>
            <a href={`/lessons/${lesson.data.slug}`} class="btn btn-secondary">Review Lesson</a>
          </div>
        </div>
      </section>

      <section class="quiz-navigation">
        {previousLesson ? (
          <a href={`/quiz/${previousLesson.data.slug}`} class="quiz-nav-card previous">
            <span class="quiz-nav-topline">
              <span class="quiz-nav-arrow" aria-hidden="true">←</span>
              <span class="quiz-nav-label">Previous quiz</span>
            </span>
            <strong>{previousLesson.data.title}</strong>
            <span>{previousLesson.data.focus}</span>
          </a>
        ) : (
          <a href="/quiz" class="quiz-nav-card fallback">
            <span class="quiz-nav-topline">
              <span class="quiz-nav-arrow" aria-hidden="true">↺</span>
              <span class="quiz-nav-label">Quiz center</span>
            </span>
            <strong>Browse all lesson quizzes</strong>
            <span>Return to the full quiz index and choose any lesson to review.</span>
          </a>
        )}
        {nextLesson ? (
          <a href={`/quiz/${nextLesson.data.slug}`} class="quiz-nav-card next">
            <span class="quiz-nav-topline">
              <span class="quiz-nav-label">Next quiz</span>
              <span class="quiz-nav-arrow" aria-hidden="true">→</span>
            </span>
            <strong>{nextLesson.data.title}</strong>
            <span>{nextLesson.data.focus}</span>
          </a>
        ) : (
          <a href="/dashboard" class="quiz-nav-card fallback">
            <span class="quiz-nav-topline">
              <span class="quiz-nav-arrow" aria-hidden="true">✓</span>
              <span class="quiz-nav-label">Track progress</span>
            </span>
            <strong>Review your saved quiz scores</strong>
            <span>Open the dashboard to see strengths, weak spots, and what to revisit next.</span>
          </a>
        )}
      </section>
    </div>
  </main>

  <script type="application/json" id="quiz-data">
    {JSON.stringify(quizQuestions)}
  </script>

  <script is:inline>
    const root = document.getElementById('quiz-app');
    const dataElement = document.getElementById('quiz-data');

    if (root && dataElement?.textContent) {
      const questions = JSON.parse(dataElement.textContent);
      const storageKey = root.getAttribute('data-storage-key') || '';
      const progressCopy = document.getElementById('progress-copy');
      const progressBar = document.getElementById('progress-bar');
      const bestScoreValue = document.getElementById('best-score-value');
      const resultsPanel = document.getElementById('quiz-results');
      const resultsSummary = document.getElementById('results-summary');
      const submitButton = document.getElementById('submit-quiz');
      const resetButton = document.getElementById('reset-quiz');
      const optionButtons = Array.from(root.querySelectorAll('.option-button'));
      const questionCards = Array.from(root.querySelectorAll('[data-question-card]'));
      const answers = new Array(questions.length).fill(null);
      const lessonSlug = storageKey.replace('grammar-atlas.quiz.', '');
      const progressApi = window.GrammarAtlasProgress;
      let submitted = false;

      const renderBestScore = () => {
        if (!bestScoreValue) {
          return;
        }

        try {
          const parsed = progressApi?.getQuizScore(lessonSlug)
            || JSON.parse(window.localStorage.getItem(storageKey) || 'null');

          if (!parsed || typeof parsed.percent !== 'number') {
            return;
          }

          bestScoreValue.textContent = `${Math.round(parsed.percent)}%`;
        } catch {}
      };

      const updateProgress = () => {
        const answered = answers.filter((answer) => answer !== null).length;

        if (progressCopy) {
          progressCopy.textContent = `${answered} of ${questions.length} answered`;
        }

        if (progressBar) {
          progressBar.style.width = `${(answered / questions.length) * 100}%`;
        }
      };

      const renderSelections = () => {
        optionButtons.forEach((button) => {
          const questionIndex = Number(button.getAttribute('data-question-index'));
          const optionIndex = Number(button.getAttribute('data-option-index'));
          const question = questions[questionIndex];
          const feedback = questionCards[questionIndex]?.querySelector('[data-feedback]');
          const isSelected = answers[questionIndex] === optionIndex;
          const isCorrect = question.correctIndex === optionIndex;

          button.classList.toggle('is-selected', isSelected);
          button.classList.toggle('is-correct', submitted && isCorrect);
          button.classList.toggle(
            'is-incorrect',
            submitted && isSelected && !isCorrect,
          );

          if (submitted) {
            button.setAttribute('aria-disabled', 'true');
          } else {
            button.removeAttribute('aria-disabled');
          }

          if (feedback instanceof HTMLElement) {
            if (!submitted) {
              feedback.hidden = true;
              feedback.textContent = '';
            } else if (answers[questionIndex] === null) {
              feedback.hidden = false;
              feedback.textContent = `No answer selected. Correct answer: ${question.options[question.correctIndex]}. ${question.explanation}`;
            } else {
              const prefix =
                answers[questionIndex] === question.correctIndex
                  ? 'Correct.'
                  : `Correct answer: ${question.options[question.correctIndex]}.`;

              feedback.hidden = false;
              feedback.textContent = `${prefix} ${question.explanation}`;
            }
          }
        });
      };

      const saveScore = (percent, correct) => {
        if (!storageKey || !lessonSlug) {
          return;
        }

        try {
          const parsed = progressApi?.getQuizScore(lessonSlug)
            || (window.localStorage.getItem(storageKey)
              ? JSON.parse(window.localStorage.getItem(storageKey))
              : null);

          if (!parsed || percent >= parsed.percent) {
            const payload = {
              percent,
              correct,
              total: questions.length,
              updatedAt: new Date().toISOString(),
            };

            if (progressApi) {
              progressApi.saveQuizScore(lessonSlug, payload);
              progressApi.updateLessonState(lessonSlug, { lastQuizPercent: percent });
            } else {
              window.localStorage.setItem(storageKey, JSON.stringify(payload));
            }
          }
        } catch {}
      };

      const submitQuiz = () => {
        if (submitted) {
          return;
        }

        submitted = true;

        const correct = questions.filter(
          (question, index) => answers[index] === question.correctIndex,
        ).length;
        const percent = (correct / questions.length) * 100;

        renderSelections();
        saveScore(percent, correct);
        renderBestScore();

        if (resultsPanel instanceof HTMLElement) {
          resultsPanel.hidden = false;
        }

        if (resultsSummary) {
          resultsSummary.textContent = `You answered ${correct} of ${questions.length} correctly (${Math.round(percent)}%).`;
        }
      };

      const resetQuiz = () => {
        submitted = false;
        answers.fill(null);

        if (resultsPanel instanceof HTMLElement) {
          resultsPanel.hidden = true;
        }

        if (resultsSummary) {
          resultsSummary.textContent = '';
        }

        renderSelections();
        updateProgress();
      };

      optionButtons.forEach((button) => {
        button.addEventListener('click', () => {
          if (submitted) {
            return;
          }

          const questionIndex = Number(button.getAttribute('data-question-index'));
          const optionIndex = Number(button.getAttribute('data-option-index'));

          answers[questionIndex] = optionIndex;
          renderSelections();
          updateProgress();
        });
      });

      submitButton?.addEventListener('click', submitQuiz);
      resetButton?.addEventListener('click', resetQuiz);

      renderBestScore();
      renderSelections();
      updateProgress();
    }
  </script>

  <style>
    .quiz-hero {
      margin-bottom: var(--space-xl);
    }

    .quiz-hero-shell {
      display: grid;
      grid-template-columns: minmax(0, 1.3fr) minmax(260px, 0.82fr);
      gap: 1.35rem 2rem;
      padding: clamp(1.7rem, 4vw, 2.8rem);
      border-radius: 1.5rem;
      position: relative;
      overflow: hidden;
      background:
        radial-gradient(circle at top right, rgba(243, 214, 172, 0.22), transparent 15rem),
        radial-gradient(circle at bottom left, rgba(63, 92, 82, 0.1), transparent 18rem),
        linear-gradient(145deg, rgba(255, 255, 255, 0.99), rgba(249, 244, 236, 0.97));
      border: 1px solid rgba(24, 34, 48, 0.08);
      box-shadow: 0 30px 60px -38px rgba(24, 34, 48, 0.34);
      color: var(--color-text);
    }

    .quiz-hero-shell::after {
      content: '';
      position: absolute;
      inset: auto 0 0;
      height: 8px;
      background: linear-gradient(90deg, rgba(63, 92, 82, 0.78), rgba(201, 111, 50, 0.7));
      opacity: 0.24;
    }

    .quiz-hero-topline {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
      grid-column: 1 / -1;
    }

    .quiz-breadcrumb {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin: 0;
      font-family: var(--font-ui);
      font-size: 0.94rem;
      color: var(--color-text-secondary);
    }

    .quiz-breadcrumb a {
      color: var(--color-primary);
    }

    .quiz-eyebrow {
      margin: 0 0 0.3rem;
      font-family: var(--font-ui);
      font-size: 0.78rem;
      letter-spacing: 0.08em;
      font-weight: var(--font-weight-semibold);
      color: var(--color-accent);
      text-transform: uppercase;
    }

    .quiz-hero-links {
      display: flex;
      gap: 0.65rem;
      flex-wrap: wrap;
    }

    .quiz-hero-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.8rem;
      padding: 0.7rem 0.95rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.76);
      color: var(--color-primary-dark);
      font-family: var(--font-ui);
      font-weight: var(--font-weight-semibold);
      text-decoration: none;
      border: 1px solid rgba(24, 34, 48, 0.08);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.74);
      transition:
        transform var(--transition-base),
        background-color var(--transition-base),
        box-shadow var(--transition-base);
    }

    .quiz-hero-link:hover {
      transform: translateY(-1px);
      background: white;
      box-shadow: var(--shadow-sm);
      text-decoration: none;
    }

    .quiz-hero-content {
      align-self: start;
    }

    .quiz-hero h1 {
      margin: 0 0 0.8rem;
      color: var(--color-primary-dark);
      font-size: clamp(2.55rem, 4.8vw, 4rem);
      max-width: 11ch;
      text-wrap: balance;
    }

    .quiz-focus {
      margin: 0;
      max-width: 38rem;
      font-size: 1.06rem;
      line-height: 1.8;
      color: var(--color-text-secondary);
      text-wrap: balance;
    }

    .quiz-hero-note {
      margin: 0.95rem 0 0;
      max-width: 38rem;
      font-size: 0.98rem;
      line-height: 1.72;
      color: var(--color-text-secondary);
    }

    .card-kicker {
      margin: 0;
      color: var(--color-accent);
      font-family: var(--font-ui);
      font-size: 0.76rem;
      font-weight: var(--font-weight-semibold);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .quiz-summary-card {
      display: grid;
      align-content: start;
      gap: 0.85rem;
      padding: 1.05rem;
      border-radius: 1.25rem;
      background: rgba(255, 255, 255, 0.74);
      border: 1px solid rgba(24, 34, 48, 0.08);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.72);
    }

    .summary-item {
      display: grid;
      gap: 0.18rem;
      padding: 0.88rem 0.92rem;
      border-radius: 0.95rem;
      background: rgba(255, 255, 255, 0.84);
      border: 1px solid rgba(24, 34, 48, 0.06);
    }

    .summary-label {
      color: var(--color-text-secondary);
      font-family: var(--font-ui);
      font-size: 0.76rem;
      font-weight: var(--font-weight-semibold);
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .summary-item strong {
      display: block;
      font-size: 1.34rem;
      margin-bottom: 0.1rem;
      color: var(--color-primary-dark);
    }

    .summary-copy {
      font-size: 0.92rem;
      color: var(--color-text-secondary);
      line-height: 1.55;
    }

    .quiz-support-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1rem;
      margin-bottom: var(--space-xl);
    }

    .support-card {
      display: grid;
      gap: 0.75rem;
      padding: 1.35rem;
      border-radius: 1.2rem;
      border: 1px solid rgba(24, 34, 48, 0.08);
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(249, 245, 238, 0.94));
      box-shadow: 0 22px 40px -34px rgba(24, 34, 48, 0.36);
      position: relative;
      overflow: hidden;
    }

    .support-card::before {
      content: '';
      position: absolute;
      inset: 0 auto 0 0;
      width: 5px;
      background: linear-gradient(180deg, rgba(63, 92, 82, 0.92), rgba(201, 111, 50, 0.88));
      opacity: 0.75;
    }

    .support-card h2 {
      margin-top: 0;
      margin-bottom: 0;
      font-size: 1.24rem;
      color: var(--color-primary-dark);
    }

    .support-card p {
      margin: 0;
      color: var(--color-text-secondary);
      font-size: 1rem;
      line-height: 1.75;
    }

    .support-links {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .quiz-panel {
      padding: clamp(1.25rem, 3vw, 1.65rem);
      border: 1px solid rgba(24, 34, 48, 0.08);
      border-radius: 1.45rem;
      background:
        radial-gradient(circle at top right, rgba(201, 111, 50, 0.08), transparent 11rem),
        linear-gradient(180deg, rgba(255, 255, 255, 0.99), rgba(249, 245, 237, 0.95));
      box-shadow: 0 28px 52px -40px rgba(24, 34, 48, 0.34);
    }

    .quiz-panel-header {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(220px, 300px);
      gap: 1.2rem;
      align-items: end;
      margin-bottom: 1.5rem;
      padding-bottom: 1.2rem;
      border-bottom: 1px solid rgba(24, 34, 48, 0.08);
    }

    .quiz-panel-copy {
      display: grid;
      gap: 0.5rem;
    }

    .quiz-panel-header h2 {
      margin: 0;
      font-size: clamp(1.48rem, 1.32rem + 0.35vw, 1.74rem);
      color: var(--color-primary-dark);
    }

    .quiz-panel-header p {
      margin: 0;
      color: var(--color-text-secondary);
      font-size: 0.98rem;
      line-height: 1.65;
    }

    .quiz-summary-card > .card-kicker,
    .support-card .card-kicker,
    .quiz-panel-copy .card-kicker {
      color: var(--color-accent);
      line-height: 1.2;
    }

    .quiz-progress-card {
      display: grid;
      gap: 0.6rem;
      padding: 0.95rem 1rem;
      border-radius: 1rem;
      background: rgba(244, 247, 246, 0.86);
      border: 1px solid rgba(24, 34, 48, 0.08);
    }

    .quiz-progress-label {
      font-family: var(--font-ui);
      font-size: 0.76rem;
      font-weight: var(--font-weight-semibold);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-accent);
    }

    .progress-meter {
      height: 0.78rem;
      background: rgba(63, 92, 82, 0.12);
      border-radius: 999px;
      overflow: hidden;
    }

    .progress-meter span {
      display: block;
      width: 0;
      height: 100%;
      background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
      transition: width var(--transition-base);
    }

    .question-list {
      display: grid;
      gap: 1rem;
    }

    .question-card {
      padding: 1.25rem 1.25rem 1.2rem 1.4rem;
      border: 1px solid rgba(24, 34, 48, 0.08);
      border-radius: 1.15rem;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.99), rgba(244, 247, 246, 0.86));
      box-shadow: 0 16px 28px -28px rgba(24, 34, 48, 0.38);
      position: relative;
      overflow: hidden;
    }

    .question-card::before {
      content: '';
      position: absolute;
